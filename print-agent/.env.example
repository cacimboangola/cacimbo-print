# URL da API do PDV na VPS (com https em produção)
API_URL=http://seu-servidor.com/api

# Identificador único da impressora (UUID gerado ao registrar)
PRINTER_IDENTIFIER=seu-identifier-aqui

# Intervalo de polling em milissegundos (padrão: 3000 = 3 segundos)
POLLING_INTERVAL=3000

# Tipo de impressora: epson, star, daruma
PRINTER_TYPE=epson

# Interface da impressora (ex: USB, rede, etc.)
# USB Windows: \\\\localhost\\NomeDaImpressora
# USB Linux: /dev/usb/lp0
# Rede: tcp://192.168.1.100:9100
PRINTER_INTERFACE=tcp://localhost:9100

# Largura do papel (caracteres por linha, usado para impressoras térmicas)
PRINTER_WIDTH=48

# Nível de log: error, warn, info, debug
LOG_LEVEL=info

# === Configurações de PDF/HTML (opcional) ===

# Formato da página para conversão HTML→PDF (A4, Letter, A5, etc.)
# PDF_PAGE_FORMAT=A4

# Orientação: false=retrato, true=paisagem
# PDF_LANDSCAPE=false

# Margens para conversão HTML→PDF (ex: 10mm, 1cm, 0.5in)
# PDF_MARGIN=10mm
