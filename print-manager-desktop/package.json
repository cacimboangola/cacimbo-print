{
  "name": "cacimbo-print-manager",
  "version": "1.0.0",
  "description": "Cacimbo Print Manager - Aplicação VPS para enviar jobs de impressão",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64",
    "build:dir": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --x64 --dir"
  },
  "author": "Cacimbo Print",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.0",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cacimboprint.manager",
    "productName": "Cacimbo Print Manager",
    "forceCodeSigning": false,
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cacimbo Print Manager"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "watcher/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  }
}
